<Window x:Class="SimpleAccountBook.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정"
        Height="200"
        Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Padding="16">
        <StackPanel>
                     <TextBlock Text="현재 조정 가능한 설정이 없습니다." FontSize="16" FontWeight="Bold" />
            <TextBlock Text="추후 업데이트를 통해 더 많은 설정을 제공할 예정입니다." Foreground="Gray" Margin="0 8 0 0" TextWrapping="Wrap" />
            <Button Content="닫기" Width="80" Margin="0 16 0 0" HorizontalAlignment="Right" Click="CloseButton_Click" />
        </StackPanel>
    </Border>
</Window>